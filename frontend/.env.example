# ==============================================================================
# Navin Frontend Environment Variables Configuration Example
# ==============================================================================
# Copy this file to a new file named '.env' in the same directory and adjust values.
# Vite requires frontend variables to be prefixed with 'VITE_' to be exposed.

# The primary base URL for backend API communications (e.g., local development server)
# Required for Axios network operations to function correctly.
VITE_API_BASE_URL=http://localhost:3000/api

# Optional: Set the application environment (development, staging, production)
VITE_APP_ENV=development
